DATABASE_URL="postgresql://postgres:postgres@localhost:5432/muzuka_gilbert"
# Supabase session pooler URL — used by Prisma migrations (port 5432, session mode).
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Encode special chars in password: @ → %40  # → %23  % → %25  / → %2F  ? → %3F
SESSION_POOLER_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

AUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Google OAuth (get from https://console.cloud.google.com)
# Authorized redirect URI: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

AWS_REGION="us-east-1"
AWS_S3_BUCKET_PRIVATE_ORIGINALS="mg-private-originals"
